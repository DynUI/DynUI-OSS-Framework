            "neverHide": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pinned": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "componentId": {
                    "type": "string"
                  },
                  "position": {
                    "enum": [
                      "top",
                      "bottom"
                    ]
