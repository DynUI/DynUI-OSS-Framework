        "stableAnchors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedCategoriesBySurface": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 0
        },
        "maxComponents": {
          "type": "integer",
          "minimum": 1
        },
        "singletons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
