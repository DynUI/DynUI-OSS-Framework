                    "type": {
                      "enum": [
                        "string",
                        "number",
                        "boolean",
                        "series",
                        "geojson",
                        "object",
                        "any"
                      ]
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "source": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "key",
                    "type",
