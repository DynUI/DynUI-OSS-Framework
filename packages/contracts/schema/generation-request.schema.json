                "componentId": {
                  "type": "string"
                },
                "variant": {
                  "type": "string"
                },
                "slots": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/UINode"
                    }
                  }
                },
                "props": {
                  "type": "object",
                  "additionalProperties": {}
                },
                "dataBindings": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "children": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/UINode"
                  }
                },
                "label": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "explanation": {
                  "type": "object",
                  "properties": {
                    "eligibility": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "nudges": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "signal": {
                            "type": "string"
                          },
                          "delta": {
                            "type": "number"
                          }
                        },
                        "additionalProperties": false,
                        "required": [
                          "signal",
                          "delta"
                        ]
                      }
                    },
                    "basePriority": {
                      "type": "number"
                    },
                    "score": {
                      "type": "number"
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "fallbackReason": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "eligibility",
                    "nudges",
                    "basePriority",
                    "score"
                  ]
                }
              },
              "additionalProperties": false,
              "required": [
                "type"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "surface",
            "generatedFor",
            "meta",
            "root"
          ]
        },
        "repairErrors": {
          "type": "array",
          "items": {}
        },
        "fallbackData": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "additionalProperties": true
    }
