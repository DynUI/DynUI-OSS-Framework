                "additionalProperties": false,
                "required": [
                  "componentId",
                  "position"
                ]
              }
            },
            "stableAnchors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowedCategoriesBySurface": {
              "type": "object",
