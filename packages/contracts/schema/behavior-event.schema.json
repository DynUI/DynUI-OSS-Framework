{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dynui.dev/schema/behavior-event.schema.json",
  "title": "BehaviorEvent",
  "type": "object",
  "properties": {
    "type": {
      "enum": [
        "exposure",
        "impression",
        "tap",
        "dwell",
        "goal",
        "dismissal",
        "render-error",
        "fallback"
      ]
    },
    "id": {
      "type": "string"
    },
    "anonId": {
      "type": "string"
    },
    "surface": {
      "type": "string"
    },
    "componentId": {
      "type": "string"
    },
    "componentVersion": {
      "type": "string"
    },
    "generationId": {
      "type": "string"
    },
    "treeKey": {
      "type": "string"
    },
    "experimentId": {
      "type": "string"
    },
    "variant": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "value": {
      "type": "number"
    },
    "ts": {
      "type": "string"
    },
    "trainable": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "required": [
    "type",
    "anonId",
    "surface",
    "ts"
  ]
}
